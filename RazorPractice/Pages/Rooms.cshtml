@page
@model RazorPractice.Pages.RoomsModel
@{
}

<h1>Meeting Rooms</h1>
<p>Here are the meeting rooms available for booking:</p>

<form method="get" class="mb-4">
    <div class="input-group">
        <input type="text" asp-for="SearchTerm" class="form-control" placeholder="Search by name or equipment..." />
        <button class="btn btn-primary">Search</button>
    </div>
</form>

<table class="table">
    <thead>
        <tr>
            <th>Status</th>
            <th>Name</th>
            <th>Capacity</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var room in Model.Rooms)
        {
            var isOccupied = Model.RoomStatus[room.Id];
            <tr>
                <td>
                    @if (isOccupied)
                    {
                        <span class="badge bg-danger">Optaget</span>
                    }
                    else
                    {
                        <span class="badge bg-success">Ledig</span>
                    }
                </td>
                <td>@room.Name</td>
                <td>@room.Capacity</td>
                <td>
                    <div class="btn-group">
                        <a asp-page="BookRoom" asp-route-id="@room.Id" class="btn btn-outline-primary btn-sm">Book</a>
                    </div>
                    <form method="post" asp-page-handler="Delete" asp-route-id="@room.Id"
                          onsubmit="return confirm('Are you sure you want to delete this room?');">
                        <button type="submit" class="btn btn-outline-danger btn-sm">Delete</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
